# SoulT AI Council — environment variables
# Copy this file to .env.local and fill in your values

# ── Turso (cloud SQLite) — required for production (Vercel) ──────────────────
# Get these from: https://turso.tech → your database → Connect
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here
# For local development these vars are optional — the app falls back to file:soulty.db

# ── Phase 2: AI Layer ────────────────────────────────────────────────────────
# Uncomment when you reach Phase 2
# ANTHROPIC_API_KEY=sk-ant-...
